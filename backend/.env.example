# ── INCOMS — Configuration Environnement ──
# Renommez ce fichier en .env avant de lancer le serveur

# Port d'écoute du serveur
PORT=3000

# Environnement (development | production)
NODE_ENV=production

# Secret JWT — CHANGEZ CETTE VALEUR EN PRODUCTION !
# Générez un secret fort avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGEZ_CE_SECRET_JWT_EN_PRODUCTION_MINIMUM_32_CHARS

# Chemin vers la base de données SQLite
DB_PATH=./data/incoms.db
